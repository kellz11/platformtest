# ── CORE platform configuration ─────────────────────────────────────────────
# Copy to .env and adjust. Load it with:  node --env-file=.env server/index.js
# (or `npm start` after exporting the variables).

# Server
PORT=8000
# Public base URL, used in emails, referral links and QR codes.
APP_URL=http://localhost:8000
# 'production' hardens cookies (Secure flag) and disables the dev mail outbox.
NODE_ENV=development

# Database (SQLite, WAL mode). Created automatically on first start.
DATABASE_FILE=./var/core.db

# Uploaded post images are stored here and served at /uploads.
UPLOAD_DIR=./var/uploads

# Initial administrator — created by `npm run seed` if the account doesn't exist.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-please
ADMIN_USERNAME=core_admin

# ── Background wallets ───────────────────────────────────────────────────────
# Production: use a managed wallet provider (Privy server wallets). When these
# are set, keys are generated and held by the provider — they never exist in
# this application or its database.
#PRIVY_APP_ID=
#PRIVY_APP_SECRET=

# Development fallback (used only when PRIVY_* is unset): keypairs are created
# locally and the secrets are AES-256-GCM encrypted into WALLET_KEYSTORE_FILE,
# which lives OUTSIDE the application database. Set a strong random key:
#   openssl rand -hex 32
WALLET_MASTER_KEY=
WALLET_KEYSTORE_FILE=./var/dev-keystore.jsonl

# ── Email ────────────────────────────────────────────────────────────────────
# In development, outgoing mail is written to the database outbox (visible at
# Admin → Dev outbox) and logged to the console. For production, connect an
# SMTP or transactional-mail provider in server/lib/email.js — see PLATFORM.md.
